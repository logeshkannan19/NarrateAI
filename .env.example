# ===================
# Application Settings
# ===================
APP_NAME=MetricFlow
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=4

# ===================
# Security
# ===================
SECRET_KEY=change-this-to-a-random-secret-key
API_TOKEN=your-api-token-here
ALLOWED_HOSTS=*

# ===================
# Database
# ===================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=metricflow
DB_USER=postgres
DB_PASSWORD=

# ===================
# Redis
# ===================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ===================
# Email Alerts
# ===================
EMAIL_ENABLED=true
SMTP_HOST=smtp.example.com
SMTP_PORT=587
EMAIL_FROM=alerts@metricflow.io
EMAIL_TO=admin@example.com

# ===================
# Slack Alerts
# ===================
SLACK_ENABLED=false
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=#alerts

# ===================
# Metrics Settings
# ===================
FLUSH_INTERVAL=10
BUFFER_SIZE=10000
RETENTION_DAYS=30

# ===================
# Features
# ===================
ENABLE_AGGREGATION=true
ENABLE_PERSISTENCE=true
ENABLE_ALERTS=true